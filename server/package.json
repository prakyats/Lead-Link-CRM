    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.18.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
