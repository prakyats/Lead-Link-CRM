# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/crm_db"

# Authentication
JWT_SECRET="your_super_secret_jwt_key_here"

# Frontend URL (used in emails/links, CORS allow-list)
FRONTEND_URL="http://localhost:5173"

# ---- Critical lead follow-up email notifications ----
# Enable scheduler
ENABLE_CRITICAL_LEAD_EMAILS=false

# Cron expression (server local time). Default: 9:00 AM daily
CRITICAL_LEAD_CRON="0 9 * * *"

# Consider follow-ups due within next N hours (default 24)
CRITICAL_LEAD_FOLLOWUP_WINDOW_HOURS=24

# SMTP configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="LeadLink CRM <your-email@example.com>"
